+void
+drawborder(struct wlr_scene_tree *t, int x, int y, int w, int h, const float c[static 4])
+{
+	struct wlr_scene_rect *r;
+
+	r = wlr_scene_rect_create(t, w, h, c);
+	wlr_scene_node_set_position(&r->node, x, y);
+}
