+int
+clientindex(Monitor *m, Client *c)
+{
+	unsigned int i = 0;
+	Client *ci;
+
+	if (!c || m->lt[m->sellt]->arrange != tile)
+		return -1;
+
+	wl_list_for_each(ci, &clients, link) {
+		if (VISIBLEON(ci, m) && !ci->isfloating && !ci->isfullscreen) {
+			if (ci == c)
+				return i;
+			else
+				i++;
+		}
+	}
+
+	return -1;
+}
